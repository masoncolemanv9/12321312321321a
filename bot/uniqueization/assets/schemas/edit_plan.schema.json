{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lilush.local/schemas/edit_plan.schema.json",
  "title": "edit_plan.json",
  "description": "Editor-v6 creative plan sidecar. Source of truth: final_spec_FULL.md Part 4.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "clip_id",
    "produced_at_iso",
    "source_path",
    "input_window",
    "profile",
    "creative_planner_status",
    "beat_sheet"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "clip_id": { "type": "string", "minLength": 1 },
    "produced_at_iso": {
      "type": "string",
      "description": "ISO-8601 UTC timestamp."
    },
    "source_path": { "type": "string" },
    "input_window": {
      "type": "object",
      "additionalProperties": false,
      "required": ["start_s", "end_s"],
      "properties": {
        "start_s": { "type": "number" },
        "end_s": { "type": "number" }
      }
    },
    "handles_used": {
      "type": "object",
      "required": ["pre_s", "post_s"],
      "properties": {
        "pre_s": { "type": "number", "minimum": 0 },
        "post_s": { "type": "number", "minimum": 0 }
      }
    },
    "profile": { "type": "string", "enum": ["light", "medium", "heavy"] },
    "style_lock_id": {
      "type": ["string", "null"],
      "description": "One of the built-in style locks from Part 12.6, or null."
    },
    "creative_planner_status": {
      "type": "string",
      "enum": ["full", "degraded", "skipped", "error"],
      "description": "Section 1.3 status taxonomy."
    },
    "creative_goal": {
      "type": "object",
      "required": ["text", "source"],
      "properties": {
        "text": { "type": "string" },
        "source": { "type": "string" },
        "confidence": { "type": "number" }
      }
    },
    "beat_sheet": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["beat_id", "start_s", "end_s", "purpose", "primary_move"],
        "properties": {
          "beat_id": { "type": "string" },
          "start_s": { "type": "number" },
          "end_s": { "type": "number" },
          "purpose": {
            "type": "string",
            "enum": [
              "hook",
              "reveal",
              "tension",
              "emotional_hold",
              "action",
              "dialogue",
              "reaction",
              "resolution",
              "transition"
            ],
            "description": "Closed §5.3 beat purpose enum."
          },
          "emotional_intent": { "type": "string" },
          "primary_move": { "type": "string" },
          "note": { "type": ["string", "null"] },
          "supports": {
            "type": "array",
            "items": { "type": "string" }
          },
          "color_intent": { "type": "string" },
          "subtitle_intensity": { "type": "string" },
          "audio_policy": { "type": "string" },
          "blur_fill": { "type": "string" },
          "reason": { "type": "string" }
        }
      }
    },
    "scene_plans": { "type": "array" },
    "zoom_curve": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["start_s", "end_s", "mode"],
        "properties": {
          "start_s": { "type": "number" },
          "end_s": { "type": "number" },
          "mode": { "type": "string" },
          "target": { "type": "string" },
          "max_zoom": { "type": "number" },
          "transition_ms": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "cuts_final": { "type": "array" },
    "mirror_decisions": { "type": "array" },
    "mirror_final": { "type": "array" },
    "timeline_map": { "type": "array" },
    "hook_overlay": { "type": ["object", "null"] },
    "frame_export_hints": { "type": "array" },
    "subtitle_plan": { "type": "object" },
    "audio_plan": { "type": "object" },
    "color_plan": { "type": "object" },
    "blur_fill_plan": { "type": "object" },
    "hook_plan": { "type": "object" },
    "manifest_reasoning": {
      "type": "array",
      "items": { "type": "string" }
    },
    "creative_intensity_score": { "type": "number", "minimum": 0, "maximum": 1 },
    "validation": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "hard_errors": { "type": "array", "items": { "type": "string" } },
        "degrade_warnings": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
